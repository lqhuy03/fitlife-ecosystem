### ==========================================
### 1. LẤY DANH SÁCH CÁC GÓI TẬP ĐANG BÁN
### ==========================================
GET {{host}}/packages
Authorization: Bearer {{jwt_token}}
Accept: application/json

### ==========================================
### 2. TẠO MỘT GÓI TẬP MỚI (CHỈ ADMIN MỚI CÓ QUYỀN)
### ==========================================
POST {{host}}/packages
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "name": "Gói PT Căn Bản 3 Tháng",
  "price": 8500000.00,
  "durationMonths": 3,
  "description": "Bao gồm 3 tháng tập luyện và 12 buổi PT 1 kèm 1.",
  "thumbnailUrl": "https://example.com/pt-package.jpg"
}

### ==========================================
### 3. LẤY THÔNG TIN CHI TIẾT 1 GÓI TẬP (Ví dụ: ID = 1)
### ==========================================
GET {{host}}/packages/1
Authorization: Bearer {{jwt_token}}
Accept: application/json