### ==========================================
### 1. LẤY DANH SÁCH TẤT CẢ CƠ SỞ (GYM BRANCHES)
### ==========================================
GET {{host}}/gym-branches
Authorization: Bearer {{jwt_token}}
Accept: application/json

### ==========================================
### 2. TẠO MỚI MỘT CƠ SỞ PHÒNG TẬP
### ==========================================
POST {{host}}/gym-branches
Authorization: Bearer {{jwt_token}}
Content-Type: application/json

{
  "name": "FitLife Premium Thủ Đức",
  "address": "Khu công nghệ cao, TP. Thủ Đức",
  "maxCapacity": 200,
  "status": "ACTIVE"
}

### ==========================================
### 3. LẤY DANH SÁCH TỦ ĐỒ THEO CƠ SỞ (Ví dụ: ID = 1)
### ==========================================
GET {{host}}/lockers/branch/1
Authorization: Bearer {{jwt_token}}
Accept: application/json